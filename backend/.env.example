ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/storage_platform
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
S3_REGION=us-west-002
S3_ACCESS_KEY_ID=your-b2-key-id
S3_SECRET_ACCESS_KEY=your-b2-application-key
S3_BUCKET_NAME=your-bucket-name

# Optional: separate public B2 bucket for thumbnails only, fronted by a CDN
# (e.g. Cloudflare). Leave both blank to fall back to presigned URLs served
# from the main (private) bucket instead.
S3_THUMBNAIL_BUCKET_NAME=
THUMBNAIL_CDN_BASE_URL=

UPLOAD_URL_EXPIRY_SECONDS=900
DOWNLOAD_URL_EXPIRY_SECONDS=3600
MULTIPART_PART_SIZE_BYTES=10485760
SINGLE_UPLOAD_THRESHOLD_BYTES=52428800

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Rate limiting — the main abuse guard now that uploads are anonymous.
UPLOAD_RATE_LIMIT_COUNT=30
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
READ_RATE_LIMIT_COUNT=300
READ_RATE_LIMIT_WINDOW_SECONDS=60
DOWNLOAD_RATE_LIMIT_COUNT=120
DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=60
DELETE_RATE_LIMIT_COUNT=30
DELETE_RATE_LIMIT_WINDOW_SECONDS=60

# Hard cap on request body size (bytes) rejected before parsing.
MAX_REQUEST_BODY_BYTES=2097152

# Global storage cap across every upload from everyone. Default 1TB.
GLOBAL_STORAGE_QUOTA_BYTES=1099511627776

# Pending (never-completed) uploads still count toward quota until this many
# seconds pass, after which they're treated as abandoned and swept out.
PENDING_UPLOAD_STALE_SECONDS=21600

# Anyone can delete their own upload within this many days; after that it's
# permanent for everyone.
DELETE_WINDOW_DAYS=3

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
